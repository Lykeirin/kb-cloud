# 环境变量配置
# 复制此文件为 .env 并修改对应值

# ============================================================
# 数据库配置（必填）
# ============================================================
# 设置一个强密码！
KB_DB_PASSWORD=change_me_to_a_strong_password

# ============================================================
# 文件目录（可选）
# ============================================================
# Watcher 监控目录（文件放入后自动入库）
# 默认: /root/kb-inbox
# KB_INBOX_DIR=/home/user/kb-inbox

# 文件处理后的归档目录
# 默认: /root/kb-archive
# KB_ARCHIVE_DIR=/home/user/kb-archive

# ============================================================
# 远程上传脚本配置（可选，用于 scripts/upload_kb.sh）
# ============================================================
# KB_REMOTE_HOST=your-server.com
# KB_REMOTE_USER=root
# KB_REMOTE_PORT=22
# KB_REMOTE_DIR=~/kb-inbox
